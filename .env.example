# =============================================================================
# Local environment variables - copy to .env.local and fill in your values.
# Never commit real secrets to git.
# =============================================================================

# App URL (used in sitemap, robots, emails, and Moolre payment callback/redirect)
# Local dev: use localhost. Production: use your live domain (e.g. https://www.sambatekgh.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (required for auth and database)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Supabase DB password (for scripts/run-migration.mjs)
# SUPABASE_DB_PASSWORD=

# reCAPTCHA (forms / bot protection)
# Get keys from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Email (Resend) - notifications, order emails
# Get API key from: https://resend.com — then verify your domain in Resend dashboard
RESEND_API_KEY=
ADMIN_EMAIL=admin@example.com
# Sender for outgoing emails — MUST use a verified domain in Resend (e.g. noreply@yourdomain.com)
# If unset, falls back to ADMIN_EMAIL or "Store <admin@example.com>"
# EMAIL_FROM=SAMBATEK Store <noreply@yourdomain.com>

# Payment provider (e.g. Moolre)
# MOOLRE_API_USER=
# MOOLRE_API_PUBKEY=
# MOOLRE_ACCOUNT_NUMBER=
# MOOLRE_MERCHANT_EMAIL=
# Callback secret: must match exactly what Moolre sends in the callback (check Moolre dashboard).
# If Moolre uses a different key or you get "Secret mismatch", set MOOLRE_SKIP_CALLBACK_SECRET=true temporarily.
# MOOLRE_CALLBACK_SECRET=
# MOOLRE_SKIP_CALLBACK_SECRET=true

# Optional: SMS (for test-sms and notifications)
# MOOLRE_SMS_API_KEY=
# MOOLRE_API_KEY=
# MOOLRE_SENDER_ID=

# Cron (Vercel cron / payment reminders) - set a secret to protect the route
CRON_SECRET=

# Admin seed (one-time: grant a user admin role)
# Used by POST /api/admin/seed-admin with Authorization: Bearer <ADMIN_SEED_SECRET>
ADMIN_SEED_SECRET=

# Optional: Branding (defaults to "Store" if unset)
# NEXT_PUBLIC_SITE_NAME=Store
# SMS_SENDER_ID=Store

# Optional: Analytics & SEO
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
